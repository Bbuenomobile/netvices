---
interface Props {
  offers: {
    name: string;
    tagline: string;
    bonus?: string;
    rating: number;
    href: string;
    color?: string;
    badge?: string;
  }[];
  sectionTitle?: string;
  color: string;
}

const { offers, sectionTitle = "Top Picks — Exclusive Deals", color } = Astro.props;
---

<section class="py-12 sm:py-20">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-10">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-[Orbitron] font-bold uppercase tracking-widest mb-4" style={`background: ${color}15; color: ${color}; border: 1px solid ${color}30;`}>
        <span class="w-2 h-2 rounded-full animate-pulse" style={`background: ${color};`}></span>
        Limited Time Offers
      </span>
      <h2 class="font-[Bungee] text-2xl sm:text-4xl" style={`color: ${color};`}>
        {sectionTitle}
      </h2>
    </div>

    <div class="space-y-4">
      {offers.map((offer, i) => (
        <a
          href={offer.href}
          target="_blank"
          rel="noopener noreferrer nofollow"
          class="affiliate-card group block relative overflow-hidden rounded-2xl border transition-all duration-300 hover:scale-[1.02]"
          style={`border-color: ${offer.color || color}30; --aff-color: ${offer.color || color};`}
        >
          <div class="relative flex flex-col sm:flex-row items-stretch">
            {/* Rank number */}
            <div class="hidden sm:flex w-20 shrink-0 items-center justify-center border-r" style={`border-color: ${offer.color || color}20; background: ${offer.color || color}08;`}>
              <span class="font-[Bungee] text-3xl" style={`color: ${offer.color || color}60;`}>#{i + 1}</span>
            </div>

            {/* Main content */}
            <div class="flex-1 p-5 sm:p-6 bg-vice-card/70 backdrop-blur-sm">
              <div class="flex flex-col sm:flex-row sm:items-center gap-4">
                {/* Info */}
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-3 mb-1">
                    {offer.badge && (
                      <span class="shrink-0 px-2.5 py-0.5 rounded-full text-[10px] font-[Orbitron] font-bold uppercase" style={`background: ${offer.color || color}20; color: ${offer.color || color};`}>
                        {offer.badge}
                      </span>
                    )}
                    <div class="flex gap-0.5">
                      {Array.from({ length: 5 }).map((_, s) => (
                        <svg class="w-4 h-4" style={`color: ${s < offer.rating ? (offer.color || color) : '#333'};`} fill="currentColor" viewBox="0 0 20 20">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                      ))}
                    </div>
                  </div>
                  <h3 class="font-[Orbitron] text-base sm:text-lg font-bold text-white group-hover:tracking-wider transition-all">
                    {offer.name}
                  </h3>
                  <p class="font-[Rajdhani] text-sm text-gray-400 mt-0.5">{offer.tagline}</p>
                </div>

                {/* Bonus */}
                {offer.bonus && (
                  <div class="shrink-0 text-center sm:text-right px-4 py-2 rounded-xl" style={`background: ${offer.color || color}10;`}>
                    <div class="font-[Bungee] text-lg sm:text-xl" style={`color: ${offer.color || color};`}>{offer.bonus}</div>
                    <div class="font-[Rajdhani] text-xs text-gray-500 uppercase">Exclusive Bonus</div>
                  </div>
                )}

                {/* CTA button */}
                <div class="shrink-0 flex items-center">
                  <span
                    class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-[Orbitron] text-xs sm:text-sm uppercase tracking-wider font-bold text-white transition-all duration-300 group-hover:scale-105 group-hover:gap-4 whitespace-nowrap"
                    style={`background: linear-gradient(135deg, ${offer.color || color}, ${offer.color || color}bb); box-shadow: 0 0 20px ${offer.color || color}30;`}
                  >
                    Visit Site
                    <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  </span>
                </div>
              </div>
            </div>
          </div>

          {/* Hover glow */}
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" style={`background: linear-gradient(135deg, ${offer.color || color}08, transparent);`}></div>
        </a>
      ))}
    </div>

    {/* Urgency bar */}
    <div class="mt-8 p-4 rounded-xl border text-center" style={`border-color: ${color}30; background: ${color}08;`}>
      <div class="flex items-center justify-center gap-3">
        <span class="w-2.5 h-2.5 rounded-full bg-red-500 animate-ping"></span>
        <span class="font-[Orbitron] text-xs sm:text-sm uppercase tracking-wider" style={`color: ${color};`}>
          <strong>2,847 users</strong> visited these sites in the last hour
        </span>
      </div>
    </div>
  </div>
</section>

<style>
  .affiliate-card:hover {
    box-shadow: 0 0 25px color-mix(in srgb, var(--aff-color) 25%, transparent);
    border-color: var(--aff-color) !important;
  }
</style>
