---
interface Props {
  title: string;
  subtitle: string;
  description: string;
  color: string;
  icon: string;
  features: { title: string; text: string; icon: string }[];
  ctaText?: string;
  ctaHref?: string;
  articles?: { title: string; excerpt: string; href: string; badge?: string }[];
  heroImage?: string;
}

const {
  title,
  subtitle,
  description,
  color,
  icon,
  features,
  ctaText = "Get Started Now",
  ctaHref = "#",
  articles = [],
  heroImage,
} = Astro.props;
---

<!-- Hero -->
<section class="relative py-20 sm:py-32 overflow-hidden">
  {heroImage && (
    <div class="absolute inset-0">
      <img src={heroImage} alt="" class="w-full h-full object-cover opacity-50" />
      <div class="absolute inset-0 bg-gradient-to-b from-vice-darker/30 via-vice-darker/50 to-vice-darker"></div>
    </div>
  )}
  <div class="absolute inset-0 opacity-10"
    style={`background: radial-gradient(ellipse at top, ${color}, transparent 60%);`}
  ></div>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 text-center relative z-10">
    <div class="text-6xl sm:text-7xl mb-6">{icon}</div>
    <h1 class="font-[Bungee] text-4xl sm:text-6xl lg:text-7xl mb-4" style={`color: ${color};`}>
      {title}
    </h1>
    <p class="font-[Orbitron] text-sm sm:text-base uppercase tracking-widest mb-6" style={`color: ${color}99;`}>
      {subtitle}
    </p>
    <p class="font-[Rajdhani] text-lg sm:text-xl text-gray-400 max-w-3xl mx-auto mb-10">
      {description}
    </p>

    <!-- Double CTA hero -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={ctaHref}
        target="_blank"
        rel="noopener noreferrer nofollow"
        class="group inline-flex items-center gap-3 px-10 py-5 rounded-xl font-[Orbitron] text-sm uppercase tracking-wider font-bold text-white transition-all duration-300 hover:scale-105"
        style={`background: linear-gradient(135deg, ${color}, ${color}bb); box-shadow: 0 0 30px ${color}40;`}
      >
        {ctaText}
        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
      <span class="font-[Rajdhani] text-sm text-gray-500 flex items-center gap-2">
        <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        Free registration — No credit card
      </span>
    </div>
  </div>
</section>

<!-- Inline CTA Banner -->
<section class="py-6">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <a
      href={ctaHref}
      target="_blank"
      rel="noopener noreferrer nofollow"
      class="group block p-5 sm:p-6 rounded-2xl border transition-all duration-300 hover:scale-[1.01]"
      style={`border-color: ${color}40; background: linear-gradient(135deg, ${color}12, ${color}05);`}
    >
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-4">
          <div class="w-3 h-3 rounded-full bg-red-500 animate-ping"></div>
          <div>
            <div class="font-[Orbitron] text-sm sm:text-base font-bold text-white">
              <span style={`color: ${color};`}>1,243 people</span> are using our #1 pick right now
            </div>
            <div class="font-[Rajdhani] text-xs text-gray-500">Join them — Exclusive bonus through our link</div>
          </div>
        </div>
        <span
          class="shrink-0 inline-flex items-center gap-2 px-6 py-3 rounded-xl font-[Orbitron] text-xs uppercase tracking-wider font-bold text-white group-hover:gap-4 transition-all"
          style={`background: linear-gradient(135deg, ${color}, ${color}cc); box-shadow: 0 0 15px ${color}30;`}
        >
          Claim Bonus
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </span>
      </div>
    </a>
  </div>
</section>

<!-- Affiliate slot: inserted by pages via slot -->
<slot name="affiliates" />

<!-- Features with embedded CTAs -->
<section class="py-16 sm:py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <h2 class="font-[Bungee] text-2xl sm:text-4xl text-center mb-12" style={`color: ${color};`}>
      Why Choose Us
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((feature, i) => (
        <div
          class="p-6 rounded-2xl border backdrop-blur-sm transition-all duration-300 hover:scale-105"
          style={`border-color: ${color}20; background: rgba(15, 0, 30, 0.7);`}
        >
          <div class="text-3xl mb-4">{feature.icon}</div>
          <h3 class="font-[Orbitron] text-lg font-bold mb-2" style={`color: ${color};`}>{feature.title}</h3>
          <p class="font-[Rajdhani] text-gray-400 text-sm">{feature.text}</p>
        </div>
      ))}
    </div>

    <!-- Mid-content CTA -->
    <div class="mt-10 text-center">
      <a
        href={ctaHref}
        target="_blank"
        rel="noopener noreferrer nofollow"
        class="group inline-flex items-center gap-3 px-10 py-4 rounded-xl font-[Orbitron] text-sm uppercase tracking-wider font-bold text-white transition-all duration-300 hover:scale-105"
        style={`background: linear-gradient(135deg, ${color}, ${color}bb); box-shadow: 0 0 25px ${color}35;`}
      >
        {ctaText} — It's Free
        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>
  </div>
</section>

<!-- Articles / Content -->
{articles.length > 0 && (
  <section class="py-16 sm:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <h2 class="font-[Bungee] text-2xl sm:text-4xl text-center mb-12" style={`color: ${color};`}>
        Latest Guides
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {articles.map((article) => (
          <a
            href={article.href}
            class="group block p-6 rounded-2xl border backdrop-blur-sm transition-all duration-300 hover:scale-[1.02]"
            style={`border-color: ${color}20; background: rgba(15, 0, 30, 0.7);`}
          >
            {article.badge && (
              <span
                class="inline-block px-3 py-1 rounded-full text-xs font-[Orbitron] font-bold uppercase mb-3"
                style={`background: ${color}20; color: ${color};`}
              >
                {article.badge}
              </span>
            )}
            <h3 class="font-[Orbitron] text-lg font-bold mb-2 group-hover:tracking-wider transition-all" style={`color: ${color};`}>
              {article.title}
            </h3>
            <p class="font-[Rajdhani] text-gray-400 text-sm">{article.excerpt}</p>
            <div class="mt-4 font-[Orbitron] text-xs uppercase tracking-wider flex items-center gap-2 group-hover:gap-4 transition-all" style={`color: ${color};`}>
              Read More
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<!-- Slot for extra page-specific content -->
<slot />

<!-- Bottom CTA — Big conversion block -->
<section class="py-16 sm:py-24">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
    <div
      class="p-8 sm:p-14 rounded-3xl border relative overflow-hidden"
      style={`border-color: ${color}40;`}
    >
      <div class="absolute inset-0 opacity-15" style={`background: radial-gradient(circle at center, ${color}, transparent 70%);`}></div>
      <div class="relative z-10">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-[Orbitron] font-bold uppercase tracking-widest mb-6" style={`background: ${color}15; color: ${color}; border: 1px solid ${color}30;`}>
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
          Available Now
        </div>
        <h2 class="font-[Bungee] text-3xl sm:text-5xl mb-4" style={`color: ${color};`}>
          Don't Wait — Start Now
        </h2>
        <p class="font-[Rajdhani] text-lg sm:text-xl text-gray-400 mb-4 max-w-2xl mx-auto">
          Join <strong style={`color: ${color};`}>thousands of users</strong> who already discovered the best the internet has to offer.
        </p>
        <p class="font-[Rajdhani] text-sm text-gray-500 mb-8">
          Free to join. No credit card required. Instant access.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href={ctaHref}
            target="_blank"
            rel="noopener noreferrer nofollow"
            class="group inline-flex items-center gap-3 px-12 py-5 rounded-xl font-[Orbitron] text-sm uppercase tracking-wider font-bold text-white transition-all duration-300 hover:scale-105"
            style={`background: linear-gradient(135deg, ${color}, ${color}bb); box-shadow: 0 0 40px ${color}50;`}
          >
            {ctaText}
            <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>
        <div class="mt-6 flex items-center justify-center gap-6 text-xs text-gray-500 font-[Rajdhani]">
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            100% Free
          </span>
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            Instant Access
          </span>
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            Discreet
          </span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Sticky bottom CTA bar (mobile) -->
<div class="fixed bottom-0 left-0 right-0 z-40 sm:hidden p-3 border-t backdrop-blur-xl" style={`border-color: ${color}30; background: rgba(5, 0, 8, 0.95);`}>
  <a
    href={ctaHref}
    target="_blank"
    rel="noopener noreferrer nofollow"
    class="flex items-center justify-center gap-2 w-full py-3.5 rounded-xl font-[Orbitron] text-xs uppercase tracking-wider font-bold text-white"
    style={`background: linear-gradient(135deg, ${color}, ${color}cc); box-shadow: 0 0 20px ${color}30;`}
  >
    {ctaText}
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
    </svg>
  </a>
</div>
