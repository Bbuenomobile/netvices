---
interface ViceBranch {
  label: string;
  href: string;
  icon: string;
  color: string;
  glowColor: string;
  image: string;
  subcategories?: { label: string; href: string }[];
}

const branches: ViceBranch[] = [
  {
    label: "Hot Social",
    href: "/hot-social",
    icon: "🔥",
    color: "#ff6ec7",
    glowColor: "rgba(255, 110, 199, 0.6)",
    image: "/images/vice-hot-social.png",
    subcategories: [
      { label: "Telegram Sex", href: "/social/telegram" },
      { label: "Snapchat Hot", href: "/social/snapchat" },
      { label: "Facebook Naughty", href: "/social/facebook" },
      { label: "TikTok Porn", href: "/social/tiktok" },
    ],
  },
  {
    label: "Cash & Games",
    href: "/cash-games",
    icon: "💰",
    color: "#ffd700",
    glowColor: "rgba(255, 215, 0, 0.6)",
    image: "/images/vice-cash-games.png",
  },
  {
    label: "Live Girls",
    href: "/live-girls",
    icon: "🎥",
    color: "#ff1493",
    glowColor: "rgba(255, 20, 147, 0.6)",
    image: "/images/vice-live-girls.png",
  },
  {
    label: "Spicy Dating",
    href: "/dating",
    icon: "💋",
    color: "#ff4500",
    glowColor: "rgba(255, 69, 0, 0.6)",
    image: "/images/vice-dating.png",
    subcategories: [
      { label: "Discreet Hookups", href: "/dating/hookups" },
      { label: "Nudes Exchange", href: "/dating/nudes" },
      { label: "Local Dates", href: "/dating/local" },
      { label: "Mature Women", href: "/dating/milf" },
    ],
  },
  {
    label: "AI Girlfriend",
    href: "/ai-girlfriend",
    icon: "🤖",
    color: "#00f5ff",
    glowColor: "rgba(0, 245, 255, 0.6)",
    image: "/images/vice-ai-girlfriend.png",
  },
];
---

<section class="relative py-20 sm:py-32 overflow-hidden" id="vice-circle">
  <!-- Section title -->
  <div class="text-center mb-16 sm:mb-24">
    <h2 class="font-[Bungee] text-3xl sm:text-5xl lg:text-6xl bg-gradient-to-r from-vice-pink via-vice-cyan to-vice-pink bg-clip-text text-transparent mb-4">
      The Circle of Vice
    </h2>
    <p class="font-[Rajdhani] text-lg sm:text-xl text-gray-400 max-w-xl mx-auto">
      Choose your pleasure. Every vice, one click away.
    </p>
  </div>

  <!-- Circle visualization -->
  <div class="relative max-w-5xl mx-auto px-4">
    <!-- Center hub -->
    <div class="vice-hub mx-auto w-32 h-32 sm:w-40 sm:h-40 rounded-full flex items-center justify-center relative z-10">
      <div class="absolute inset-0 rounded-full bg-gradient-to-br from-vice-magenta via-vice-purple to-vice-deep-purple animate-[spin_20s_linear_infinite] opacity-50"></div>
      <div class="absolute inset-1 rounded-full bg-vice-darker flex items-center justify-center">
        <span class="font-[Bungee] text-xl sm:text-2xl text-vice-pink neon-text">VICE</span>
      </div>
    </div>

    <!-- Branches - Grid layout for all screens -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-12 sm:mt-16">
      {branches.map((branch, index) => (
        <a
          href={branch.href}
          class="vice-branch-card group relative overflow-hidden rounded-2xl border transition-all duration-500 hover:scale-105"
          style={`border-color: ${branch.color}30; --branch-color: ${branch.color}; --branch-glow: ${branch.glowColor};`}
          data-index={index}
        >
          {/* Background image */}
          <div class="absolute inset-0">
            <img src={branch.image} alt="" class="w-full h-full object-cover opacity-60 group-hover:opacity-75 group-hover:scale-110 transition-all duration-700" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-vice-darker via-vice-darker/50 to-vice-darker/20"></div>
          </div>

          {/* Glow effect */}
          <div
            class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
            style={`background: radial-gradient(ellipse at center, ${branch.glowColor}, transparent 70%);`}
          ></div>

          {/* Content */}
          <div class="relative p-6 sm:p-8" style="text-shadow: 0 2px 10px rgba(0,0,0,0.9), 0 0 20px rgba(0,0,0,0.5);">
            {/* Icon */}
            <div class="text-4xl sm:text-5xl mb-4">{branch.icon}</div>

            {/* Label */}
            <h3
              class="font-[Bungee] text-xl sm:text-2xl mb-3 transition-all duration-300"
              style={`color: ${branch.color};`}
            >
              {branch.label}
            </h3>

            {/* Connector line */}
            <div
              class="w-16 h-0.5 mb-4 transition-all duration-500 group-hover:w-full"
              style={`background: linear-gradient(90deg, ${branch.color}, transparent);`}
            ></div>

            {/* Subcategories */}
            {branch.subcategories && (
              <ul class="space-y-2">
                {branch.subcategories.map((sub) => (
                  <li class="flex items-center gap-2 text-sm text-gray-400 group-hover:text-gray-300 transition-colors">
                    <span class="w-1.5 h-1.5 rounded-full" style={`background: ${branch.color};`}></span>
                    {sub.label}
                  </li>
                ))}
              </ul>
            )}

            {!branch.subcategories && (
              <p class="text-sm text-gray-400 group-hover:text-gray-300 transition-colors">
                Explore the best {branch.label.toLowerCase()} content →
              </p>
            )}

            {/* Arrow */}
            <div class="absolute top-6 right-6 opacity-0 group-hover:opacity-100 transform translate-x-2 group-hover:translate-x-0 transition-all duration-300">
              <svg class="w-6 h-6" style={`color: ${branch.color};`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .vice-branch-card {
    box-shadow: 0 0 15px rgba(0, 0, 0, 0.3);
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .vice-branch-card:hover {
    box-shadow: 0 0 30px var(--branch-glow), 0 0 60px color-mix(in srgb, var(--branch-glow) 30%, transparent);
    border-color: var(--branch-color) !important;
  }
  .vice-hub {
    box-shadow: 0 0 40px rgba(232, 0, 130, 0.4), 0 0 80px rgba(155, 48, 255, 0.2);
  }
</style>
