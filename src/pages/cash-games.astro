        { name: "1xBet", tagline: "The largest sportsbook. Best odds on football, UFC, esports.", bonus: "$500 FREE BET", rating: 4, href: "#", color: "#ff6600" },
        { name: "Roobet", tagline: "Crash games, slots, and live casino. Used by top streamers.", bonus: "FREE SPINS", rating: 4, href: "#", color: "#ffd700", badge: "POPULAR" },
