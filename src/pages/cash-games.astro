      { title: "Sports Betting 101: From Beginner To Pro", excerpt: "Master the art of sports betting. Value bets, accumulators, live betting strategies, and bankroll management.", href: "#", badge: "Guide" },
    ]}
  >
    <div slot="affiliates">
      <AffiliateBlock color="#ffd700" sectionTitle="Top Online Casinos — Exclusive Bonuses" offers={[
        { name: "Stake Casino", tagline: "Crypto casino with the best odds. Instant withdrawals, no KYC.", bonus: "$1,000 BONUS", rating: 5, href: "#", color: "#ffd700", badge: "#1 CASINO" },
