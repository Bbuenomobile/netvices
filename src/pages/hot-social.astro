---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Hot Social Networks — NetVices" description="Discover the hottest adult content on Telegram, Snapchat, Facebook, and TikTok. Your guide to NSFW social media.">

  <!-- Banner -->
  <div class="bg-gradient-to-r from-vice-pink via-vice-magenta to-vice-pink py-2.5 sm:py-3 text-center">
    <span class="font-[Orbitron] text-xs sm:text-base uppercase tracking-widest text-white font-bold">
      🔥 Hot Social Networks 🔥
    </span>
  </div>

  <!-- Cards Stack -->
  <div class="max-w-2xl mx-auto px-6 sm:px-4 pt-2.5 pb-10 space-y-2.5 sm:space-y-4">

    <!-- Telegram Sex -->
    <a href="/social/telegram" class="vice-block group block relative overflow-hidden rounded-xl sm:rounded-2xl" style="--block-color: #0088cc;">
      <div class="relative">
        <img src="/images/sub-telegram.png" alt="Telegram Sex" class="w-full vice-card-img object-cover" loading="eager" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
        <div class="absolute top-1.5 left-2 sm:top-3 sm:left-3">
          <span class="px-1.5 py-0.5 sm:px-2.5 sm:py-1 rounded-full text-[8px] sm:text-[10px] font-[Orbitron] font-bold uppercase bg-[#0088cc] text-white">✈️ Telegram</span>
        </div>
        <div class="absolute bottom-0 left-0 right-0 p-2.5 sm:p-6 flex items-end justify-between gap-2">
          <div>
            <h2 class="font-[Bungee] text-base sm:text-3xl text-white leading-none" style="text-shadow: 0 2px 10px rgba(0,0,0,0.8);">
              TELEGRAM SEX
            </h2>
            <p class="font-[Rajdhani] text-[10px] sm:text-sm text-gray-300 mt-0.5">Secret groups & free NSFW channels</p>
          </div>
          <div class="shrink-0 text-2xl sm:text-5xl animate-[bounce_1s_ease-in-out_infinite]">👉</div>
        </div>
      </div>
    </a>

    <!-- Snapchat Hot -->
    <a href="/social/snapchat" class="vice-block group block relative overflow-hidden rounded-xl sm:rounded-2xl" style="--block-color: #FFFC00;">
      <div class="relative">
        <img src="/images/sub-snapchat.png" alt="Snapchat Hot" class="w-full vice-card-img object-cover" loading="eager" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
        <div class="absolute top-1.5 left-2 sm:top-3 sm:left-3">
          <span class="px-1.5 py-0.5 sm:px-2.5 sm:py-1 rounded-full text-[8px] sm:text-[10px] font-[Orbitron] font-bold uppercase bg-yellow-400 text-black">👻 Snapchat</span>
        </div>
        <div class="absolute bottom-0 left-0 right-0 p-2.5 sm:p-6 flex items-end justify-between gap-2">
          <div>
            <h2 class="font-[Bungee] text-base sm:text-3xl text-white leading-none" style="text-shadow: 0 2px 10px rgba(0,0,0,0.8);">
              SNAPCHAT HOT
            </h2>
            <p class="font-[Rajdhani] text-[10px] sm:text-sm text-gray-300 mt-0.5">Premium accounts & exclusive snaps</p>
          </div>
          <div class="shrink-0 text-2xl sm:text-5xl animate-[bounce_1s_ease-in-out_infinite]">👉</div>
        </div>
      </div>
    </a>

    <!-- Facebook Coquin -->
    <a href="/social/facebook" class="vice-block group block relative overflow-hidden rounded-xl sm:rounded-2xl" style="--block-color: #1877F2;">
      <div class="relative">
        <img src="/images/sub-facebook.png" alt="Facebook Naughty" class="w-full vice-card-img object-cover" loading="eager" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
        <div class="absolute top-1.5 left-2 sm:top-3 sm:left-3">
          <span class="px-1.5 py-0.5 sm:px-2.5 sm:py-1 rounded-full text-[8px] sm:text-[10px] font-[Orbitron] font-bold uppercase bg-[#1877F2] text-white">📘 Facebook</span>
        </div>
        <div class="absolute bottom-0 left-0 right-0 p-2.5 sm:p-6 flex items-end justify-between gap-2">
          <div>
            <h2 class="font-[Bungee] text-base sm:text-3xl text-white leading-none" style="text-shadow: 0 2px 10px rgba(0,0,0,0.8);">
              FACEBOOK NAUGHTY
            </h2>
            <p class="font-[Rajdhani] text-[10px] sm:text-sm text-gray-300 mt-0.5">Secret groups & hidden content</p>
          </div>
          <div class="shrink-0 text-2xl sm:text-5xl animate-[bounce_1s_ease-in-out_infinite]">👉</div>
        </div>
      </div>
    </a>

    <!-- TikTok Porn -->
    <a href="/social/tiktok" class="vice-block group block relative overflow-hidden rounded-xl sm:rounded-2xl" style="--block-color: #ff0050;">
      <div class="relative">
        <img src="/images/sub-tiktok.png" alt="TikTok Porn" class="w-full vice-card-img object-cover" loading="eager" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
        <div class="absolute top-1.5 left-2 sm:top-3 sm:left-3">
          <span class="px-1.5 py-0.5 sm:px-2.5 sm:py-1 rounded-full text-[8px] sm:text-[10px] font-[Orbitron] font-bold uppercase bg-[#ff0050] text-white">🎵 Viral</span>
        </div>
        <div class="absolute bottom-0 left-0 right-0 p-2.5 sm:p-6 flex items-end justify-between gap-2">
          <div>
            <h2 class="font-[Bungee] text-base sm:text-3xl text-white leading-none" style="text-shadow: 0 2px 10px rgba(0,0,0,0.8);">
              TIKTOK PORN
            </h2>
            <p class="font-[Rajdhani] text-[10px] sm:text-sm text-gray-300 mt-0.5">Uncensored TikTok & adult creators</p>
          </div>
          <div class="shrink-0 text-2xl sm:text-5xl animate-[bounce_1s_ease-in-out_infinite]">👉</div>
        </div>
      </div>
    </a>

    <!-- Back to home -->
    <div class="pt-4 text-center">
      <a href="/" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-vice-pink/20 border border-vice-pink/40 hover:bg-vice-pink/30 transition-all font-[Orbitron] text-xs uppercase tracking-wider text-vice-pink">
        ← Back to all vices
      </a>
    </div>

  </div>

  <style>
    .vice-card-img {
      aspect-ratio: 5/2;
      object-position: top center;
    }
    @media (min-width: 640px) {
      .vice-card-img {
        aspect-ratio: 16/9;
        object-position: center;
      }
    }
    .vice-block {
      border: 2px solid color-mix(in srgb, var(--block-color) 30%, transparent);
      transition: all 0.3s ease;
    }
    .vice-block:hover {
      border-color: var(--block-color);
      box-shadow: 0 0 25px color-mix(in srgb, var(--block-color) 40%, transparent);
      transform: scale(1.02);
    }
    .vice-block img {
      transition: transform 0.5s ease;
    }
    .vice-block:hover img {
      transform: scale(1.05);
    }
  </style>

</Layout>
