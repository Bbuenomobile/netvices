---
import Layout from '../layouts/Layout.astro';
---

<Layout title="NetVices — Every Vice The Internet Has To Offer" description="Your ultimate guide to online adult entertainment, dating, live cams, AI girlfriends, and more. Explore every vice at netvices.net.">

  <!-- Banner -->
  <div class="bg-gradient-to-r from-vice-pink via-vice-magenta to-vice-pink py-2.5 sm:py-3 text-center">
    <span class="font-[Orbitron] text-xs sm:text-base uppercase tracking-widest text-white font-bold">
      🔥 Choose your vice below 🔥
    </span>
  </div>

  <!-- Vice Blocks Stack -->
  <div class="max-w-2xl mx-auto px-2 sm:px-4 pb-10 space-y-1.5 sm:space-y-4">

    <!-- BLOCK 1: Hot Social -->
    <a href="/hot-social" class="vice-block group block relative overflow-hidden rounded-xl sm:rounded-2xl" style="--block-color: #ff6ec7;">
      <div class="relative">
        <img src="/images/vice-hot-social.png" alt="Hot Social" class="w-full vice-card-img object-cover" loading="eager" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
        <div class="absolute top-1.5 left-2 sm:top-3 sm:left-3">
          <span class="px-1.5 py-0.5 sm:px-2.5 sm:py-1 rounded-full text-[8px] sm:text-[10px] font-[Orbitron] font-bold uppercase bg-vice-pink text-white">🔥 Hot</span>
        </div>
        <div class="absolute bottom-0 left-0 right-0 p-2.5 sm:p-6 flex items-end justify-between gap-2">
          <div>
            <h2 class="font-[Bungee] text-base sm:text-3xl text-white leading-none" style="text-shadow: 0 2px 10px rgba(0,0,0,0.8);">
              HOT SOCIAL NETWORKS
            </h2>
            <p class="font-[Rajdhani] text-[10px] sm:text-sm text-gray-300 mt-0.5">Telegram, Snapchat, TikTok, Facebook</p>
          </div>
          <div class="shrink-0 text-2xl sm:text-5xl animate-[bounce_1s_ease-in-out_infinite]">👉</div>
        </div>
      </div>
    </a>

    <!-- BLOCK 2: Cash & Games -->
    <a href="/cash-games" class="vice-block group block relative overflow-hidden rounded-xl sm:rounded-2xl" style="--block-color: #ffd700;">
      <div class="relative">
        <img src="/images/vice-cash-games.png" alt="Cash Games" class="w-full vice-card-img object-cover" loading="eager" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
        <div class="absolute top-1.5 left-2 sm:top-3 sm:left-3">
          <span class="px-1.5 py-0.5 sm:px-2.5 sm:py-1 rounded-full text-[8px] sm:text-[10px] font-[Orbitron] font-bold uppercase bg-yellow-500 text-black">💰 Money</span>
        </div>
        <div class="absolute bottom-0 left-0 right-0 p-2.5 sm:p-6 flex items-end justify-between gap-2">
          <div>
            <h2 class="font-[Bungee] text-base sm:text-3xl text-white leading-none" style="text-shadow: 0 2px 10px rgba(0,0,0,0.8);">
              WIN CASH ONLINE
            </h2>
            <p class="font-[Rajdhani] text-[10px] sm:text-sm text-gray-300 mt-0.5">Casinos, Betting, Poker, Crypto</p>
          </div>
          <div class="shrink-0 text-2xl sm:text-5xl animate-[bounce_1s_ease-in-out_infinite]">👉</div>
        </div>
      </div>
    </a>

    <!-- BLOCK 3: Live Girls -->
    <a href="/live-girls" class="vice-block group block relative overflow-hidden rounded-xl sm:rounded-2xl" style="--block-color: #ff1493;">
      <div class="relative">
        <img src="/images/vice-live-girls.png" alt="Live Girls" class="w-full vice-card-img object-cover" loading="eager" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
        <div class="absolute top-1.5 left-2 sm:top-3 sm:left-3">
          <span class="px-1.5 py-0.5 sm:px-2.5 sm:py-1 rounded-full text-[8px] sm:text-[10px] font-[Orbitron] font-bold uppercase bg-red-600 text-white animate-pulse">🔴 Live</span>
        </div>
        <div class="absolute bottom-0 left-0 right-0 p-2.5 sm:p-6 flex items-end justify-between gap-2">
          <div>
            <h2 class="font-[Bungee] text-base sm:text-3xl text-white leading-none" style="text-shadow: 0 2px 10px rgba(0,0,0,0.8);">
              FREE LIVE SEX CAMS
            </h2>
            <p class="font-[Rajdhani] text-[10px] sm:text-sm text-gray-300 mt-0.5">Watch for free, 24/7 live shows</p>
          </div>
          <div class="shrink-0 text-2xl sm:text-5xl animate-[bounce_1s_ease-in-out_infinite]">👉</div>
        </div>
      </div>
    </a>

    <!-- BLOCK 4: Spicy Dating -->
    <a href="/dating" class="vice-block group block relative overflow-hidden rounded-xl sm:rounded-2xl" style="--block-color: #ff4500;">
      <div class="relative">
        <img src="/images/vice-dating.png" alt="Dating" class="w-full vice-card-img object-cover" loading="eager" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
        <div class="absolute top-1.5 left-2 sm:top-3 sm:left-3">
          <span class="px-1.5 py-0.5 sm:px-2.5 sm:py-1 rounded-full text-[8px] sm:text-[10px] font-[Orbitron] font-bold uppercase bg-vice-sunset text-white">💋 Popular</span>
        </div>
        <div class="absolute bottom-0 left-0 right-0 p-2.5 sm:p-6 flex items-end justify-between gap-2">
          <div>
            <h2 class="font-[Bungee] text-base sm:text-3xl text-white leading-none" style="text-shadow: 0 2px 10px rgba(0,0,0,0.8);">
              FIND A HOOKUP
            </h2>
            <p class="font-[Rajdhani] text-[10px] sm:text-sm text-gray-300 mt-0.5">Discreet. Near you. Tonight.</p>
          </div>
          <div class="shrink-0 text-2xl sm:text-5xl animate-[bounce_1s_ease-in-out_infinite]">👉</div>
        </div>
      </div>
    </a>

    <!-- BLOCK 5: AI Girlfriend -->
    <a href="/ai-girlfriend" class="vice-block group block relative overflow-hidden rounded-xl sm:rounded-2xl" style="--block-color: #00f5ff;">
      <div class="relative">
        <img src="/images/vice-ai-girlfriend.png" alt="AI Girlfriend" class="w-full vice-card-img object-cover" loading="eager" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
        <div class="absolute top-1.5 left-2 sm:top-3 sm:left-3">
          <span class="px-1.5 py-0.5 sm:px-2.5 sm:py-1 rounded-full text-[8px] sm:text-[10px] font-[Orbitron] font-bold uppercase bg-vice-cyan text-black">🤖 New</span>
        </div>
        <div class="absolute bottom-0 left-0 right-0 p-2.5 sm:p-6 flex items-end justify-between gap-2">
          <div>
            <h2 class="font-[Bungee] text-base sm:text-3xl text-white leading-none" style="text-shadow: 0 2px 10px rgba(0,0,0,0.8);">
              AI GIRLFRIEND
            </h2>
            <p class="font-[Rajdhani] text-[10px] sm:text-sm text-gray-300 mt-0.5">Chat, flirt, photos — your dream girl</p>
          </div>
          <div class="shrink-0 text-2xl sm:text-5xl animate-[bounce_1s_ease-in-out_infinite]">👉</div>
        </div>
      </div>
    </a>

    <!-- Share section -->
    <div class="pt-4 sm:pt-6 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 sm:px-4 sm:py-2 rounded-full border border-vice-pink/30 bg-vice-pink/10 mb-3">
        <span class="font-[Orbitron] text-[10px] sm:text-xs uppercase tracking-wider text-vice-pink">Share with your friends</span>
      </div>
      <div class="flex items-center justify-center gap-3 sm:gap-4">
        <a href="#" class="w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-green-600 flex items-center justify-center hover:scale-110 transition-transform" aria-label="WhatsApp">
          <svg class="w-5 h-5 sm:w-6 sm:h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        </a>
        <a href="#" class="w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-blue-500 flex items-center justify-center hover:scale-110 transition-transform" aria-label="Telegram">
          <svg class="w-5 h-5 sm:w-6 sm:h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0a12 12 0 00-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 01.171.325c.016.093.036.306.02.472-.18 1.898-.96 6.504-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.492-1.302.48-.428-.013-1.252-.242-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
        </a>
        <a href="#" class="w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-blue-700 flex items-center justify-center hover:scale-110 transition-transform" aria-label="Facebook">
          <svg class="w-5 h-5 sm:w-6 sm:h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href="#" class="w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-sky-500 flex items-center justify-center hover:scale-110 transition-transform" aria-label="Twitter">
          <svg class="w-5 h-5 sm:w-6 sm:h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
      </div>
    </div>

  </div>

  <style>
    .vice-card-img {
      aspect-ratio: 2/1;
      object-position: top center;
    }
    @media (min-width: 640px) {
      .vice-card-img {
        aspect-ratio: 16/9;
        object-position: center;
      }
    }
    .vice-block {
      border: 2px solid color-mix(in srgb, var(--block-color) 30%, transparent);
      transition: all 0.3s ease;
    }
    .vice-block:hover {
      border-color: var(--block-color);
      box-shadow: 0 0 25px color-mix(in srgb, var(--block-color) 40%, transparent);
      transform: scale(1.02);
    }
    .vice-block img {
      transition: transform 0.5s ease;
    }
    .vice-block:hover img {
      transform: scale(1.05);
    }
  </style>

</Layout>
